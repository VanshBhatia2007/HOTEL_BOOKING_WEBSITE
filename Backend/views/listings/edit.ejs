<% layout("/layouts/boilerplate") %>
<body>
<div class="row mt-3">
    <div class="col-8 offset-2">
     <h3>edit the listng</h3>
    <form method="post" action="/listings/<%= listing._id %>?_method=PUT">
        <div class="mb-3">
            <label class="form-label" for="title" >Title: </label>
            <input type="text" name="listing[title]" placeholder="enter title" class="form-control" value="<%= listing.title %>">
        </div>
        <div class="mb-3">
            <label class="form-label" for="description">Description: </label>
            <textarea name="listing[description]" placeholder="enter description" class="form-control"><%= listing.description %></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label" for="image">Image URL: </label>
            <input type="text" name="listing[image]" placeholder="enter the url" class="form-control" value="<%= listing.image.url %>">
        </div>
        <div class="row">
                <div class="mb-3 col-md-4">
                    <label class="form-label" for="price">Price: </label>
                    <input type="number" name="listing[price]" placeholder="enter the price" class="form-control" value="<%= listing.price %>">
                </div>
                <div class="mb-3 col-md-4">
                    <label class="form-label" for="country">Country: </label>
                    <input type="text" name="listing[country]" placeholder="enter the country" class="form-control" value="<%= listing.country %>">
                </div>
                
            </div>
        <div class="mb-3">
            <label class="form-label" for="location">Loaction: </label>
            <input type="text" name="listing[location]" placeholder="enter the location" class="form-control" value="<%= listing.location %>">
        </div>
        <button class="btn btn-dark edit-btn">Edit</button>
    </form>
    </div>
</div>
</div>
</body>
