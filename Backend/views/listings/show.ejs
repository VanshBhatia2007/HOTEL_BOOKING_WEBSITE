<% layout("/layouts/boilerplate") %>
<div class="row">
    <div class="col-6 offset-2">
    <h3>Hotel details:</h3>
    <div class="card col-6 offset-3 show-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="..." >
        <div class="card-body">
            <p class="card-text">
                <%= listing.title %> <br>
                <%= listing.description %> <br>
                &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> <br>
                <%= listing.location %> <br>
                <%= listing.country %>
            </p>
        </div>
    </div>
    <br>
    <div class="btns offset-3">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">edit the listing</a>
        <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
            <button class="btn btn-dark">DELETE LISTING</button>
        </form>
    </div>
    
    </div>
</div>