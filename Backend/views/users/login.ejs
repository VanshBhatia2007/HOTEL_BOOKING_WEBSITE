<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-6 offset-3">
        <h1 class="col-6 offset-3">login</h1>
        <form action="/login" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
                <label class="form-label" for="username">Username: </label>
                <input type="text" id="username" name="username" placeholder="enter Username" class="form-control" required>
                <div class="valid-feedback">Username looks good</div>
            </div>
            <div class="mb-3">
                <label class="form-label" for="password">Password: </label>
                <input type="password" name="password" id="password" placeholder="enter Password" class="form-control" required>
                <div class="valid-feedback">Password looks strong</div>
            </div>
            <button class="btn btn-success add-btn">login</button>
        </form>
    </div>
</div>